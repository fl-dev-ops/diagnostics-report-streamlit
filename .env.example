# Read-only Postgres connections. The app only ever issues SELECT queries.
# Prod and Dev are selected via the Environment toggle in the sidebar.

# Prod environment. Non-libpq query parameters copied from database GUI tools
# are ignored by the app.
PROD_DATABASE_URL="postgresql://user:password@host/proddb?sslmode=require"
PROD_REPORT_BASE_URL="https://diagnostics.intervoo.ai"

# Dev environment.
DEV_DATABASE_URL="postgresql://user:password@host/devdb?sslmode=require"
DEV_REPORT_BASE_URL="https://dev.diagnostics.intervoo.ai"
